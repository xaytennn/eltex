CC = gcc
CFLAGS = -Wall
TARGET_SERVER = server
TARGET_CLIENT = client
TARGET_CONNECTION = connection_defs

all: $(TARGET_SERVER) $(TARGET_CLIENT)


$(TARGET_SERVER): $(TARGET_SERVER).c $(TARGET_CONNECTION).c
	$(CC) $(CFLAGS) $(TARGET_SERVER).c $(TARGET_CONNECTION).c -o $(TARGET_SERVER) 


$(TARGET_CLIENT): $(TARGET_CLIENT).c $(TARGET_CONNECTION).c
	$(CC) $(CFLAGS) $(TARGET_CLIENT).c $(TARGET_CONNECTION).c -o $(TARGET_CLIENT) 


clean:
	rm -f $(TARGET_SERVER) $(TARGET_CLIENT)

.PHONY: all clean 
