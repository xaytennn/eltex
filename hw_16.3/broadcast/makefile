CC = gcc
CFLAGS = -Wall
TARGET_BROADCAST = broadcast
TARGET_CLIENT = client

all: $(TARGET_BROADCAST) $(TARGET_CLIENT)

$(TARGET_BROADCAST): $(TARGET_BROADCAST).c
	$(CC) $(CFLAGS) $(TARGET_BROADCAST).c -o $(TARGET_BROADCAST) 


$(TARGET_CLIENT): $(TARGET_CLIENT).c
	$(CC) $(CFLAGS) $(TARGET_CLIENT).c -o $(TARGET_CLIENT) 

clean:
	rm -f $(TARGET_BROADCAST) $(TARGET_CLIENT)

.PHONY: all clean 
