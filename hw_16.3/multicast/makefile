CC = gcc
CFLAGS = -Wall
TARGET_MULTICAST = multicast
TARGET_CLIENT = client

all: $(TARGET_MULTICAST) $(TARGET_CLIENT)

$(TARGET_MULTICAST): $(TARGET_MULTICAST).c
	$(CC) $(CFLAGS) $(TARGET_MULTICAST).c -o $(TARGET_MULTICAST) 

$(TARGET_CLIENT): $(TARGET_CLIENT).c
	$(CC) $(CFLAGS) $(TARGET_CLIENT).c -o $(TARGET_CLIENT) 

clean:
	rm -f $(TARGET_MULTICAST) $(TARGET_CLIENT) 

.PHONY: all clean 
